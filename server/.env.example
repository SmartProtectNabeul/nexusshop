PORT=5000

# ─── Supabase Credentials ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── Database Connection Strings ─────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  → Use the "Session pooler" URI (port 5432)
#                 This is used by Prisma at runtime for all queries.
#                 Format: postgresql://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"

# DIRECT_URL    → Use the "Direct connection" URI (port 5432, under "Connection string > URI" tab)
#                 Prisma uses this ONLY for `prisma db push` and `prisma migrate`.
#                 Direct connections bypass the pooler, which is required for migrations.
#                 Format: postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ─── Stripe Credentials ──────────────────────────────────────────────────────
# Found in: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Found in: https://dashboard.stripe.com/test/webhooks (after creating a webhook endpoint)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App Config ──────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
